# Copier ce fichier en "keystore.properties" (même dossier) et le remplir.
# NE JAMAIS commiter le fichier "keystore.properties" réel ni le .keystore/.jks
# (déjà exclus dans .gitignore).
#
# Pour générer une clé de signature release (à faire UNE SEULE FOIS, à garder
# précieusement — Google ne permet pas de la changer après la 1ère publication
# sans passer par leur process de "key upgrade"/Play App Signing) :
#
#   keytool -genkey -v -keystore tibus-passenger-release.keystore \
#     -alias tibus-passenger -keyalg RSA -keysize 2048 -validity 10000
#
# Placer le .keystore généré dans ce dossier (android-passenger/) puis renseigner :
storeFile=tibus-passenger-release.keystore
storePassword=CHANGE_ME
keyAlias=tibus-passenger
keyPassword=CHANGE_ME
