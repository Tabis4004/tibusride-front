# =============================================================================
# Tibus Ride — variables d'environnement
# Copiez vers .env (local) et configurez aussi sur Vercel → Settings → Environment Variables
# Prod : https://tibusride-front.vercel.app
# =============================================================================

# ─── Supabase (obligatoire) ───────────────────────────────────────────────────
# Dashboard : https://supabase.com/dashboard/project/bjtklpjdsmqmzhncfflu/settings/api
# Auth → URL Configuration : ajoutez https://tibusride-front.vercel.app/** dans Redirect URLs

SUPABASE_URL=https://bjtklpjdsmqmzhncfflu.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=bjtklpjdsmqmzhncfflu

# Préfixe VITE_ = exposé au navigateur (build client)
VITE_SUPABASE_URL=https://bjtklpjdsmqmzhncfflu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=bjtklpjdsmqmzhncfflu

# ─── App URL ──────────────────────────────────────────────────────────────────
# Local
VITE_APP_URL=http://localhost:8080
DEV_PORT=8080

# Vercel (à mettre dans le dashboard Vercel, pas seulement en local) :
# VITE_APP_URL=https://tibusride-front.vercel.app

# ─── Google Maps (obligatoire pour la carte) ──────────────────────────────────
# Clé NAVIGATEUR — restrictions Sites web :
#   Dev  : http://localhost:8080/* … http://localhost:8082/*
#   Prod : https://tibusride-front.vercel.app/*
# Restrictions API → "Ne pas restreindre" (dev) ou Maps JavaScript API (prod)

VITE_GOOGLE_MAPS_BROWSER_KEY=

# Clé SERVEUR — Geocoding, Routes, Places (server functions)
# Restrictions application : Aucune (appels serveur Vercel)
GOOGLE_MAPS_API_KEY=

# ─── GeniusPay / Mobile Money (optionnel) ─────────────────────────────────────
# Sans ces clés, le top-up wallet ne fonctionne pas (le reste de l'app oui)

GENIUSPAY_PUBLIC_KEY=
GENIUSPAY_API_KEY=
GENIUSPAY_WEBHOOK_SECRET=
# Fallback legacy
TOPUP_WEBHOOK_SECRET=
