# ─── App URL ──────────────────────────────────────────────────────────────────
# Local
VITE_APP_URL=http://localhost:8080
DEV_PORT=8080

# Vercel (à mettre dans le dashboard Vercel, pas seulement en local) :
# VITE_APP_URL=https://tibusride-front.vercel.app

# ─── Google Maps (obligatoire pour la carte) ──────────────────────────────────
# Clé NAVIGATEUR — restrictions Sites web :
#   Dev  : http://localhost:8080/* … http://localhost:8082/*
#   Prod : https://tibusride-front.vercel.app/*
# Restrictions API → "Ne pas restreindre" (dev) ou Maps JavaScript API (prod)

VITE_GOOGLE_MAPS_BROWSER_KEY=

# Clé SERVEUR — Geocoding, Routes, Places (server functions)
# Restrictions application : Aucune (appels serveur Vercel)
GOOGLE_MAPS_API_KEY=

# ─── GeniusPay / Mobile Money (optionnel) ─────────────────────────────────────
# Sans ces clés, le top-up wallet ne fonctionne pas (le reste de l'app oui)

GENIUSPAY_PUBLIC_KEY=
GENIUSPAY_API_KEY=
GENIUSPAY_WEBHOOK_SECRET=
# Fallback legacy
TOPUP_WEBHOOK_SECRET=

# ─── Resend (formulaire /contact) ─────────────────────────────────────────────
# Sans cette clé, le formulaire de contact affiche une erreur (mais email et
# WhatsApp restent affichés sur la page en repli).
# 1. Créer un compte gratuit sur https://resend.com avec l'email
#    tabistibus@gmail.com (ou changer CONTACT_RECIPIENT_EMAIL ci-dessous).
# 2. Dashboard Resend → API Keys → créer une clé → la coller ici.
# Tant qu'aucun domaine n'est vérifié sur Resend, l'envoi se fait depuis
# onboarding@resend.dev et UNIQUEMENT vers l'email du compte Resend
# (limitation du mode test) — donc CONTACT_RECIPIENT_EMAIL doit être cet
# email-là.
RESEND_API_KEY=
CONTACT_RECIPIENT_EMAIL=tabistibus@gmail.com
