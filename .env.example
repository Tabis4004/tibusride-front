# ─── OBLIGATOIRE pour se connecter / créer un compte ───

# Supabase → Project Settings → Database → Connection string → URI
# Choisir "Transaction" ou "Session", remplacer [YOUR-PASSWORD] par le mot de passe DB
POSTGRES_URL=postgresql://postgres:[YOUR-PASSWORD]@localhost:5432/tibusride

# Secret pour les cookies de session (min. 16 caractères, inventez une longue chaîne)
AUTH_SECRET=your-auth-secret-min-32-characters

# ─── Google OAuth direct (local, sans Supabase) ───
# Redirect URI dans Google Cloud : http://localhost:8080/auth/callback

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Supabase (recopiez depuis votre .env actuel) ───

SUPABASE_URL=https://[VOTRE-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_PROJECT_ID=[VOTRE-REF]

# Préfixe VITE_ = accessible côté navigateur (carte, client Supabase si réactivé)
VITE_SUPABASE_URL=https://[VOTRE-REF].supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=[VOTRE-REF]

# ─── Google Maps (recopiez depuis votre .env actuel) ───

VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=AIza...
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID=...

# ─── OPTIONNEL (cartes côté serveur, paiements) ───

GOOGLE_MAPS_API_KEY=
LOVABLE_API_KEY=
GENIUSPAY_PUBLIC_KEY=
GENIUSPAY_API_KEY=
GENIUSPAY_WEBHOOK_SECRET=
TOPUP_WEBHOOK_SECRET=

RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Tibus Ride <onboarding@your-domain.com>
